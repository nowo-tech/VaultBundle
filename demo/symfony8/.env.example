# APP_ENV: Symfony environment. Demos run in `dev`.
APP_ENV=dev

# APP_DEBUG: enable Symfony debug in demos.
APP_DEBUG=true

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker

# APP_SECRET: local-only app secret for cookies/tokens.
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: host port exposed by the demo web server.
PORT=8023

# DEFAULT_URI: URL opened in browser after startup.
DEFAULT_URI=http://localhost:8023

# MYSQL_ROOT_PASSWORD: local root password for the MySQL container.
MYSQL_ROOT_PASSWORD=root

# MYSQL_DATABASE: schema used by the demo application.
MYSQL_DATABASE=vault_demo

# MYSQL_USER: application user for DB access.
MYSQL_USER=demo

# MYSQL_PASSWORD: application password for DB access.
MYSQL_PASSWORD=demo

# DATABASE_URL: Doctrine DSN using the Docker service hostname.
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4

# Base64-encoded 32-byte libsodium key for vault payload encryption (demo only).
# Generate: php -r 'echo base64_encode(random_bytes(32)), PHP_EOL;'
VAULT_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Halite key for DoctrineEncryptBundle (encrypts vault_settings.encryption_key in DB).
# Generate: php bin/console doctrine:encrypt:generate-secret-key vault_settings
DOCTRINE_ENCRYPT_KEY=31400500d0b5ab953d58518336c5749017ffbeba5bf3d85171e4d82882e4dc64294856ea720288f9a59e1d933ec1e1c8196e82957df2591c9887a96c0e37e5e99a0672f80f6a1c180c1522901938c5d736e742be6bfa16874b0209df0f805edc86b0116a
