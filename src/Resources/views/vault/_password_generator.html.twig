<div class="vault-password-modal" data-vault-password-modal hidden>
    <div class="vault-password-modal-backdrop" data-vault-password-close></div>
    <div class="vault-password-modal-panel card shadow-sm" role="dialog" aria-modal="true">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h3 class="card-title mb-0">{{ 'vault.generator.title'|trans({}, 'NowoVaultBundle') }}</h3>
            <button type="button" class="btn-close" data-vault-password-close aria-label="Close"></button>
        </div>
        <div class="card-body">
            <div class="input-group mb-3">
                <input type="text" class="form-control" readonly data-vault-password-output>
                <button type="button" class="btn btn-outline-secondary" data-vault-password-regenerate>{{ 'vault.generator.regenerate'|trans({}, 'NowoVaultBundle') }}</button>
                <button type="button" class="btn btn-outline-secondary" data-vault-password-copy>{{ 'vault.generator.copy'|trans({}, 'NowoVaultBundle') }}</button>
            </div>
            <p class="text-secondary small" data-vault-password-strength></p>
            <label class="form-label">
                <span>{{ 'vault.generator.length'|trans({}, 'NowoVaultBundle') }}</span>
                <input type="range" class="form-range" min="8" max="64" value="20" data-vault-password-length>
            </label>
            <fieldset class="mb-3">
                <label class="form-check"><input type="radio" class="form-check-input" name="vault-gen-mode" value="characters" checked> {{ 'vault.generator.mode_characters'|trans({}, 'NowoVaultBundle') }}</label>
                <label class="form-check"><input type="radio" class="form-check-input" name="vault-gen-mode" value="words"> {{ 'vault.generator.mode_words'|trans({}, 'NowoVaultBundle') }}</label>
            </fieldset>
            <fieldset class="mb-3">
                <label class="form-check form-check-inline"><input type="checkbox" class="form-check-input" data-vault-password-upper checked> A-Z</label>
                <label class="form-check form-check-inline"><input type="checkbox" class="form-check-input" data-vault-password-digits checked> 0-9</label>
                <label class="form-check form-check-inline"><input type="checkbox" class="form-check-input" data-vault-password-symbols checked> !@#</label>
            </fieldset>
            <button type="button" class="btn btn-primary" data-vault-password-fill>{{ 'vault.generator.fill'|trans({}, 'NowoVaultBundle') }}</button>
        </div>
    </div>
</div>
