{% if form.vars.grantee_picker %}
    <div class="col-md-8">{{ form_row(form.granteeSelection) }}</div>
    <div class="col-md-4">{{ form_row(form.permission) }}</div>
{% else %}
    <div class="col-md-4">{{ form_row(form.granteeType) }}</div>
    <div class="col-md-4">{{ form_row(form.granteeId) }}</div>
    <div class="col-md-4">{{ form_row(form.permission) }}</div>
{% endif %}
