{% extends layout %}

{% if tagInputEnabled|default(false) %}
    {% form_theme form '@NowoVaultBundle/Form/vault_item_form_theme.html.twig' %}
{% else %}
    {% form_theme form 'bootstrap_5_layout.html.twig' %}
{% endif %}

{% block title %}{{ ('vault.type.' ~ itemType.value)|trans({}, 'NowoVaultBundle') }}{% endblock %}

{% block styles %}
    {{ parent() }}
    {% if tagInputEnabled|default(false) %}
        <link rel="stylesheet" href="{{ asset('bundles/nowotaginput/tag-input.css') }}">
    {% endif %}
{% endblock %}

{% block body %}
    {% include '@NowoVaultBundle/vault/_page_header.html.twig' with {
        pageTitle: ('vault.type.' ~ itemType.value)|trans({}, 'NowoVaultBundle'),
    } %}

    {% include '@NowoVaultBundle/vault/_flashes.html.twig' %}

    <div class="card">
        <div class="card-body">
            {% if readOnly|default(false) and not viewMode|default(false) %}
                <div class="alert alert-info">{{ 'vault.read_only.notice'|trans({}, 'NowoVaultBundle') }}</div>
            {% endif %}

            {{ form_start(form, {attr: {class: 'vault-form', 'data-vault-item-form': itemType.value, 'data-vault-readonly': readOnly|default(false) ? '1' : '0'}}) }}

            {{ form_row(form.title) }}

            {% if itemType.value == 'login' %}
                {{ form_row(form.username) }}
                {{ form_row(form.password) }}
                <div class="mb-3">
                    {{ form_label(form.websites) }}
                    {% for websiteField in form.websites %}
                        <div class="mb-2">
                            {{ form_widget(websiteField, {attr: {class: 'form-control', placeholder: 'https://example.com'}}) }}
                            {{ form_errors(websiteField) }}
                        </div>
                    {% endfor %}
                    {{ form_errors(form.websites) }}
                </div>
            {% elseif itemType.value == 'secure_note' %}
                {{ form_row(form.secureNote) }}
            {% elseif itemType.value == 'credit_card' %}
                {{ form_row(form.cardholderName) }}
                {{ form_row(form.cardNumber) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.expiry) }}</div>
                    <div class="col-md-6">{{ form_row(form.cvv) }}</div>
                </div>
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.cardPin) }}</div>
                    <div class="col-md-6">{{ form_row(form.postalCode) }}</div>
                </div>
            {% elseif itemType.value == 'contact' %}
                {{ form_row(form.fullName) }}
                {{ form_row(form.email) }}
                {{ form_row(form.phone) }}
                {{ form_row(form.addressLine1) }}
                {{ form_row(form.addressLine2) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.city) }}</div>
                    <div class="col-md-6">{{ form_row(form.state) }}</div>
                </div>
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.postalCode) }}</div>
                    <div class="col-md-6">{{ form_row(form.country) }}</div>
                </div>
            {% else %}
                {{ form_row(form.fullName) }}
                {{ form_row(form.documentNumber) }}
                {{ form_row(form.issuedBy) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.issuedDate) }}</div>
                    <div class="col-md-6">{{ form_row(form.expiryDate) }}</div>
                </div>
                {% if not readOnly|default(false) %}
                    <div class="mb-3">
                        <label class="form-label">{{ 'vault.form.attachment'|trans({}, 'NowoVaultBundle') }}</label>
                        <input type="file" name="attachment" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp">
                    </div>
                {% endif %}
            {% endif %}

            {% if folders is empty %}
                <p class="text-secondary small mb-2">
                    {{ 'vault.folder.empty_hint'|trans({}, 'NowoVaultBundle') }}
                    <a href="{{ path(routes.items.name) }}">{{ 'vault.nav.folders'|trans({}, 'NowoVaultBundle') }}</a>
                </p>
            {% endif %}
            {{ form_row(form.folder) }}

            {% if tagInputEnabled|default(false) %}
                {{ form_row(form.tags) }}
                <p class="form-text text-secondary">{{ 'vault.form.tags_help'|trans({}, 'NowoVaultBundle') }}</p>
            {% else %}
                <div class="mb-3">
                    {{ form_label(form.tags) }}
                    {% for tagField in form.tags %}
                        <div class="mb-2">
                            {{ form_widget(tagField, {attr: {class: 'form-control', placeholder: 'vault.form.tag_placeholder'|trans({}, 'NowoVaultBundle')}}) }}
                            {{ form_errors(tagField) }}
                        </div>
                    {% endfor %}
                    {{ form_errors(form.tags) }}
                    <p class="form-text text-secondary mb-0">{{ 'vault.form.tags_help'|trans({}, 'NowoVaultBundle') }}</p>
                </div>
            {% endif %}

            {{ form_row(form.note) }}

            {{ form_widget(form._token) }}

            <div class="d-flex gap-2 mt-4">
                {% if not readOnly|default(false) %}
                    <button type="submit" class="btn btn-primary">{{ 'vault.action.save'|trans({}, 'NowoVaultBundle') }}</button>
                {% endif %}
                <a href="{{ path(routes.items.name, activeFolder|default(null) ? {folder: activeFolder} : {}) }}" class="btn btn-outline-secondary">{{ 'vault.action.back'|trans({}, 'NowoVaultBundle') }}</a>
            </div>

            {{ form_end(form, {render_rest: false}) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if tagInputEnabled|default(false) %}
        <script src="{{ asset('bundles/nowotaginput/tag-input.js') }}" defer></script>
    {% endif %}
    {% if passwordStrengthEnabled|default(false) %}
        <script src="{{ asset('bundles/passwordstrength/password-strength.js') }}" defer></script>
    {% else %}
        <script>
            window.VAULT_PASSWORD_URL = {{ path(routes.password_generate.name)|json_encode|raw }};
            window.VAULT_PASSWORD_CSRF_TOKEN = {{ csrf_token('vault_password_generate')|json_encode|raw }};
        </script>
    {% endif %}
{% endblock %}
