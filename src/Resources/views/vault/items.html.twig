{% extends layout %}

{% block title %}{{ 'vault.home.items.title'|trans({}, 'NowoVaultBundle') }}{% endblock %}

{% block body %}
    {% include '@NowoVaultBundle/vault/_page_header.html.twig' with {
        pageTitle: 'vault.home.items.title'|trans({}, 'NowoVaultBundle'),
        pageSubtitle: 'vault.home.items.description'|trans({}, 'NowoVaultBundle'),
    } %}

    {% include '@NowoVaultBundle/vault/_flashes.html.twig' %}

    <div class="card mb-4">
        <div class="card-body">
            <form class="row g-3 align-items-end" method="get" action="{{ path(routes.items.name) }}">
                {% if activeFolder|default(null) %}
                    <input type="hidden" name="folder" value="{{ activeFolder }}">
                {% endif %}
                {% if activeTag|default(null) %}
                    <input type="hidden" name="tag" value="{{ activeTag }}">
                {% endif %}
                <div class="col-md-8">
                    <label class="form-label" for="vault-search">{{ 'vault.search.placeholder'|trans({}, 'NowoVaultBundle') }}</label>
                    <input id="vault-search" type="search" name="q" class="form-control" value="{{ searchQuery|default('') }}" placeholder="{{ 'vault.search.placeholder_tags'|trans({}, 'NowoVaultBundle') }}">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">{{ 'vault.action.search'|trans({}, 'NowoVaultBundle') }}</button>
                </div>
            </form>
        </div>
    </div>

    {% if tags is not empty %}
        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <span class="text-secondary small">{{ 'vault.tags.filter'|trans({}, 'NowoVaultBundle') }}:</span>
                    {% set allTagsParams = searchQuery|default('') ? {q: searchQuery} : {} %}
                    {% if activeFolder|default(null) %}
                        {% set allTagsParams = allTagsParams|merge({folder: activeFolder}) %}
                    {% endif %}
                    <a href="{{ path(routes.items.name, allTagsParams) }}"
                       class="btn btn-sm {% if activeTag|default(null) is null %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                        {{ 'vault.tags.all'|trans({}, 'NowoVaultBundle') }}
                    </a>
                    {% for tag in tags %}
                        {% set tagParams = {tag: tag.id} %}
                        {% if activeFolder|default(null) %}
                            {% set tagParams = tagParams|merge({folder: activeFolder}) %}
                        {% endif %}
                        {% if searchQuery|default('') %}
                            {% set tagParams = tagParams|merge({q: searchQuery}) %}
                        {% endif %}
                        {% set tagActive = activeTag|default(null) == tag.id %}
                        <div class="btn-group vault-tag-actions" role="group" aria-label="{{ tag.name }}">
                            <a href="{{ path(routes.items.name, tagParams) }}"
                               class="btn btn-sm {% if tagActive %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                                {{ tag.name }}
                            </a>
                            <form method="post"
                                  action="{{ path(routes.tag_delete.name, {id: tag.id}) }}"
                                  class="vault-tag-action-form"
                                  onsubmit="return confirm('{{ 'vault.confirm.delete_tag'|trans({'%name%': tag.name}, 'NowoVaultBundle')|e('js') }}');">
                                <input type="hidden" name="_token" value="{{ csrf_token('vault_tag_delete_' ~ tag.id) }}">
                                {% if activeFolder|default(null) %}
                                    <input type="hidden" name="folder" value="{{ activeFolder }}">
                                {% endif %}
                                {% if searchQuery|default('') %}
                                    <input type="hidden" name="q" value="{{ searchQuery }}">
                                {% endif %}
                                {% if activeTag|default(null) %}
                                    <input type="hidden" name="tag" value="{{ activeTag }}">
                                {% endif %}
                                <button type="submit"
                                        class="btn btn-sm btn-icon {% if tagActive %}btn-primary{% else %}btn-outline-secondary{% endif %} text-danger"
                                        title="{{ 'vault.action.delete_tag'|trans({}, 'NowoVaultBundle') }}">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                </button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
            <h3 class="card-title mb-0">{{ 'vault.nav.folders'|trans({}, 'NowoVaultBundle') }}</h3>
            <button type="button" class="btn btn-sm btn-outline-primary" data-vault-folder-toggle>
                {{ 'vault.folder.add'|trans({}, 'NowoVaultBundle') }}
            </button>
        </div>
        <div class="card-body">
            <form method="post" action="{{ path(routes.folder_create.name) }}" class="row g-2 mb-3" data-vault-folder-form hidden>
                <input type="hidden" name="_token" value="{{ csrf_token('vault_folder_create') }}">
                <div class="col">
                    <input type="text" name="name" class="form-control" placeholder="{{ 'vault.folder.name_placeholder'|trans({}, 'NowoVaultBundle') }}" required>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">{{ 'vault.action.save'|trans({}, 'NowoVaultBundle') }}</button>
                </div>
            </form>
            <div class="d-flex flex-wrap align-items-center gap-2 vault-folder-list">
                <a href="{{ path(routes.items.name, searchQuery|default('') ? {q: searchQuery} : {}) }}"
                   class="btn btn-sm {% if activeFolder|default(null) is null %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                    {{ 'vault.folder.all'|trans({}, 'NowoVaultBundle') }}
                </a>
                {% for folder in folders %}
                    {% set folderActive = activeFolder|default(null) == folder.id %}
                    {% set folderItemCount = folderItemCounts[folder.id]|default(0) %}
                    {% set trashFolderConfirm = folderItemCount > 0
                        ? 'vault.confirm.trash_folder_with_items'|trans({'%count%': folderItemCount}, 'NowoVaultBundle')
                        : 'vault.confirm.trash_folder'|trans({}, 'NowoVaultBundle') %}
                    <div class="btn-group vault-folder-actions" role="group" aria-label="{{ folder.name }}">
                        <a href="{{ path(routes.items.name, {folder: folder.id}) }}"
                           class="btn btn-sm {% if folderActive %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                            {{ folder.name }}
                        </a>
                        <a href="{{ path(routes.folder_share.name, {id: folder.id}) }}"
                           class="btn btn-sm btn-icon {% if folderActive %}btn-primary{% else %}btn-outline-secondary{% endif %}"
                           title="{{ 'vault.share.manage'|trans({}, 'NowoVaultBundle') }}">
                            <i class="ti ti-share" aria-hidden="true"></i>
                        </a>
                        <form method="post"
                              action="{{ path(routes.folder_trash.name, {id: folder.id}) }}"
                              class="vault-folder-action-form"
                              onsubmit="return confirm('{{ trashFolderConfirm|e('js') }}');">
                            <input type="hidden" name="_token" value="{{ csrf_token('vault_folder_trash_' ~ folder.id) }}">
                            <button type="submit"
                                    class="btn btn-sm btn-icon {% if folderActive %}btn-primary{% else %}btn-outline-secondary{% endif %} text-danger"
                                    title="{{ 'vault.action.trash'|trans({}, 'NowoVaultBundle') }}">
                                <i class="ti ti-trash" aria-hidden="true"></i>
                            </button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
            <h3 class="card-title mb-0">{{ 'vault.home.items.title'|trans({}, 'NowoVaultBundle') }}</h3>
            <div class="d-flex flex-wrap gap-2">
                {% for type in itemTypes %}
                    {% set newItemParams = {type: type.value} %}
                    {% if activeFolder|default(null) %}
                        {% set newItemParams = newItemParams|merge({folder: activeFolder}) %}
                    {% endif %}
                    <a href="{{ path(routes.item_new.name, newItemParams) }}" class="btn btn-sm btn-outline-primary">
                        {{ ('vault.type.' ~ type.value)|trans({}, 'NowoVaultBundle') }}
                    </a>
                {% endfor %}
            </div>
        </div>
        <div class="card-body p-0">
            {% if items is empty %}
                <p class="text-secondary p-4 mb-0">{{ 'vault.empty.items'|trans({}, 'NowoVaultBundle') }}</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-vcenter card-table mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'vault.list.type'|trans({}, 'NowoVaultBundle') }}</th>
                                <th>{{ 'vault.form.title'|trans({}, 'NowoVaultBundle') }}</th>
                                <th>{{ 'vault.form.tags'|trans({}, 'NowoVaultBundle') }}</th>
                                <th>{{ 'vault.list.folder'|trans({}, 'NowoVaultBundle') }}</th>
                                <th class="w-1">{{ 'vault.list.actions'|trans({}, 'NowoVaultBundle') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in items %}
                                <tr>
                                    <td class="text-secondary">{{ ('vault.type.' ~ item.itemType.value)|trans({}, 'NowoVaultBundle') }}</td>
                                    <td>
                                        <a href="{{ path(routes.item_view.name, {id: item.id}) }}">
                                            {{ item.title }}
                                        </a>
                                        {% if readOnlyMap[item.id]|default(false) %}
                                            <span class="badge bg-azure-lt ms-1">{{ 'vault.badge.read_only'|trans({}, 'NowoVaultBundle') }}</span>
                                        {% endif %}
                                        {% if grantCounts[item.id]|default(0) > 0 %}
                                            <span class="badge bg-green-lt ms-1">{{ 'vault.access.shared_badge'|trans({}, 'NowoVaultBundle') }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if item.tags is empty %}
                                            <span class="text-secondary">—</span>
                                        {% else %}
                                            <div class="d-flex flex-wrap gap-1">
                                                {% for tag in item.tags %}
                                                    {% set tagLinkParams = {tag: tag.id} %}
                                                    {% if activeFolder|default(null) %}
                                                        {% set tagLinkParams = tagLinkParams|merge({folder: activeFolder}) %}
                                                    {% endif %}
                                                    <a href="{{ path(routes.items.name, tagLinkParams) }}" class="badge bg-azure-lt text-azure">{{ tag.name }}</a>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td class="text-secondary">
                                        {% if item.folder %}
                                            <a href="{{ path(routes.items.name, {folder: item.folder.id}) }}">{{ item.folder.name }}</a>
                                        {% else %}
                                            {{ 'vault.form.no_folder'|trans({}, 'NowoVaultBundle') }}
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% include '@NowoVaultBundle/vault/_item_row_actions.html.twig' with {
                                            item: item,
                                            readOnlyMap: readOnlyMap,
                                            routes: routes,
                                        } %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>window.VAULT_PASSWORD_URL = {{ path(routes.password_generate.name)|json_encode|raw }};</script>
{% endblock %}
