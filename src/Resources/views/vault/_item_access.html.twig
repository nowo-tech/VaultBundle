{% if item %}
    <div class="card mt-4">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ 'vault.access.title'|trans({}, 'NowoVaultBundle') }}</h3>
        </div>
        <div class="card-body">
            <p class="text-secondary">{{ 'vault.access.intro'|trans({}, 'NowoVaultBundle') }}</p>

            {% include '@NowoVaultBundle/vault/_grants_table.html.twig' with {
                grants: grants,
                resourceId: item.id,
                grantRevokeRoute: routes.item_grant_revoke.name,
                canManageAccess: canManageAccess|default(false),
                granteeLabels: granteeLabels|default({}),
            } %}

            {% if canManageAccess|default(false) and shareForm %}
                <hr class="my-4">
                <h4 class="h5">{{ 'vault.access.add'|trans({}, 'NowoVaultBundle') }}</h4>
                {% form_theme shareForm 'bootstrap_5_layout.html.twig' %}
                {{ form_start(shareForm, {
                    action: path(routes.item_share.name, {id: item.id}),
                    attr: {class: 'vault-share-form'},
                }) }}
                <div class="row g-3">
                    {% include '@NowoVaultBundle/vault/_share_form_fields.html.twig' with {form: shareForm} %}
                </div>
                {% if not shareForm.vars.grantee_picker %}
                    <p class="text-secondary small mb-3">{{ 'vault.share.grantee_id_help'|trans({}, 'NowoVaultBundle') }}</p>
                {% endif %}
                <button type="submit" class="btn btn-outline-primary">{{ 'vault.share.submit'|trans({}, 'NowoVaultBundle') }}</button>
                {{ form_end(shareForm, {render_rest: false}) }}
            {% endif %}
        </div>
    </div>
{% endif %}
